# Required for live AI calls
OPENAI_API_KEY=sk-...

# Recommended model choices
DEFAULT_MODEL=gpt-5.4-mini
SUMMARY_MODEL=gpt-5.4-nano
FINAL_MODEL=gpt-5.4-mini

# Per-student usage control
CREDIT_BUDGET_PER_USER=30000
KRW_PER_CREDIT=0.1
USD_TO_KRW=1400
MAX_PERSONAS=5
MAX_ROUNDS_PER_SESSION=6
MAX_MESSAGES_PER_SESSION=80
MAX_OUTPUT_TOKENS=700

# Access-code mode. Leave false for open classroom testing.
REQUIRE_ACCESS_CODE=false
ACCESS_CODES=student01,student02,student03
CLASSROOM_SHARED_SECRET=change-this-classroom-secret

# Optional persistent database. Railway Postgres or Neon works.
# If omitted, the app uses an in-memory store and resets when restarted.
DATABASE_URL=

# Railway/Express
PORT=3000
NODE_ENV=production
