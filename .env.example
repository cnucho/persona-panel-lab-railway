# Required for live AI calls. Leave empty for local mock-mode testing.
OPENAI_API_KEY=sk-...

# Model choices.
# Economy/balanced requests use DEFAULT_MODEL.
# Deep requests use PREMIUM_MODEL.
# Summaries use SUMMARY_MODEL.
DEFAULT_MODEL=gpt-4.1-mini
SUMMARY_MODEL=gpt-4.1-nano
EDITOR_MODEL=gpt-4.1-nano
PREMIUM_MODEL=gpt-4.1

# Per-user usage control.
CREDIT_BUDGET_PER_USER=30000
KRW_PER_CREDIT=0.1
USD_TO_KRW=1400
MAX_PERSONAS=5
MAX_ROUNDS_PER_SESSION=8
MAX_MESSAGES_PER_SESSION=100
MAX_OUTPUT_TOKENS=700

# Access-code mode. Leave false for open classroom testing.
REQUIRE_ACCESS_CODE=false
ACCESS_CODES=student01,student02,student03
CLASSROOM_SHARED_SECRET=change-this-classroom-secret

# Optional central login/credit server. When enabled, users sign in by email/password
# and the central server grants the first 30,000 app credits on first verified login.
CENTRAL_AUTH_URL=https://ai-login-credit-admin-server-production.up.railway.app
CENTRAL_AUTH_SECRET=
SHARED_SESSION_COOKIE=shared_ai_session
APP_ID=persona-panel-lab
APP_NAME=Persona Panel Lab
APP_URL=http://localhost:3000
APP_VISIBILITY=public
APP_ALLOWED_EMAILS=
APP_USAGE_TIER=standard
APP_CREDIT_POLICIES=consumerinsight.kr=0,*=10
APP_CREDIT_MARKUP=10
STARTER_ACTUAL_COST_KRW=3000

# Optional persistent database. Railway Postgres or Neon works.
# If omitted, the app uses an in-memory store and resets when restarted.
DATABASE_URL=

# Railway/Express
PORT=3000
NODE_ENV=production
